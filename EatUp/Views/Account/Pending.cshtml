@{ ViewData["Title"] = "Aplicație trimisă"; }

<div class="auth-page">
    <div class="auth-card text-center" style="max-width:520px;">
        <div style="font-size:3.5rem; margin-bottom:1rem;">⏳</div>
        <h2 class="fw-700 mb-2" style="font-size:1.4rem;">Aplicația ta este în analiză!</h2>
        <p class="text-muted mb-4" style="font-size:.9rem; line-height:1.6;">
            Am primit cererea ta de înregistrare a restaurantului. Echipa noastră o va analiza și
            vei primi un email cu decizia în cel mai scurt timp.
        </p>

        <div class="d-flex flex-column gap-2 align-items-center">
            <div class="d-flex align-items-center gap-2 text-muted" style="font-size:.875rem;">
                <span style="color:var(--orange); font-size:1.1rem;">✓</span>
                Aplicație primită cu succes
            </div>
            <div class="d-flex align-items-center gap-2 text-muted" style="font-size:.875rem;">
                <span style="color:var(--orange); font-size:1.1rem;">⋯</span>
                În așteptarea aprobării admin
            </div>
            <div class="d-flex align-items-center gap-2 text-muted" style="font-size:.875rem;">
                <span style="color:var(--gray-400); font-size:1.1rem;">○</span>
                Cont activ pe EatUp
            </div>
        </div>

        <hr class="my-4" />

        <a asp-controller="Home" asp-action="Index" class="btn btn-orange px-4">
            Înapoi la pagina principală
        </a>
    </div>
</div>
