@{ ViewData["Title"] = "Cont suspendat"; }

<div class="auth-page">
    <div class="auth-card text-center" style="max-width:480px;">
        <div style="font-size:3.5rem; margin-bottom:1rem;">🚫</div>
        <h2 class="fw-700 mb-2" style="font-size:1.4rem;">Contul tău a fost suspendat</h2>
        <p class="text-muted mb-4" style="font-size:.9rem; line-height:1.6;">
            Contul tău a fost suspendat de echipa de administrare EatUp.
            Dacă crezi că este o eroare, contactează-ne la
            <a href="mailto:support@eatup.ro" class="text-orange">support@eatup.ro</a>.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-orange px-4">
            Pagina principală
        </a>
    </div>
</div>
