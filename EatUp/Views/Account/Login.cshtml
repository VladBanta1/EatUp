@model LoginViewModel
@{ ViewData["Title"] = "Autentificare"; }

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">EatUp</div>
        <p class="auth-subtitle">Bun venit înapoi! Conectează-te la contul tău.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 px-3 mb-3" style="font-size:.875rem;"></div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="exemplu@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Parolă</label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label" style="font-size:.875rem;">Ține-mă minte</label>
                </div>
            </div>

            <button type="submit" class="btn btn-orange w-100 py-2 mb-3">Autentificare</button>

            <p class="text-center mb-0" style="font-size:.875rem; color:var(--gray-600);">
                Nu ai cont?
                <a asp-action="Register" class="text-orange fw-600 text-decoration-none">Înregistrează-te</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
