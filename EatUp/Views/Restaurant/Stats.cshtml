@model EatUp.ViewModels.RestaurantStatsViewModel
@{ ViewData["Title"] = "Dashboard"; }

<section class="py-4 py-lg-5">
    <div class="container">

        @if ((bool?)ViewBag.HasApprovedItems == false)
        {
            <div class="alert d-flex align-items-start gap-3 mb-4"
                 style="background:#fff7ed; border:1px solid #fed7aa; border-left:4px solid #f97316; border-radius:12px;">
                <span style="font-size:1.25rem; flex-shrink:0; line-height:1.4;">⚠️</span>
                <div>
                    <strong>Restaurantul tău nu este vizibil publicului.</strong>
                    <div class="small mt-1 text-muted">
                        Adaugă cel puțin un produs aprobat pentru a apărea în lista de restaurante.
                    </div>
                </div>
            </div>
        }

        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
            <div>
                <h2 class="fw-800 mb-1" style="font-size:1.5rem;">Dashboard — @Model.Restaurant.Name</h2>
                <p class="text-muted mb-0 small">Performanța restaurantului tău.</p>
            </div>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-orange btn-sm active" id="btn7" onclick="setPeriod(7)">7 zile</button>
                <button type="button" class="btn btn-outline-orange btn-sm" id="btn30" onclick="setPeriod(30)">30 zile</button>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card-eatup p-4 text-center">
                    <div id="cardOrders" style="font-size:1.8rem; font-weight:800; color:var(--orange);">@Model.TotalOrders7d</div>
                    <div class="text-muted" style="font-size:.8rem;">Comenzi livrate</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card-eatup p-4 text-center">
                    <div id="cardRevenue" style="font-size:1.5rem; font-weight:800; color:var(--orange);">@Model.TotalRevenue7d.ToString("0") RON</div>
                    <div class="text-muted" style="font-size:.8rem;">Venituri</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card-eatup p-4 text-center">
                    <div style="font-size:1.8rem; font-weight:800; color:var(--orange);">@Model.Restaurant.Rating.ToString("0.0") ★</div>
                    <div class="text-muted" style="font-size:.8rem;">Rating mediu</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card-eatup p-4 text-center">
                    <div style="font-size:1.8rem; font-weight:800; color:var(--orange);">@Model.Restaurant.TotalReviews</div>
                    <div class="text-muted" style="font-size:.8rem;">Recenzii totale</div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="card-eatup p-4">
                    <h6 class="fw-700 mb-3">Comenzi livrate per zi</h6>
                    <div style="height:220px;"><canvas id="ordersChart"></canvas></div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card-eatup p-4">
                    <h6 class="fw-700 mb-3">Venituri per zi — RON</h6>
                    <div style="height:220px;"><canvas id="revenueChart"></canvas></div>
                </div>
            </div>
        </div>

        <div class="card-eatup p-4">
            <h6 class="fw-700 mb-3">Top 5 cele mai vândute produse (30 zile)</h6>
            @if (!Model.TopItems.Any())
            {
                <div class="text-muted small text-center py-3">Niciun produs vândut în această perioadă.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0" style="font-size:.9rem;">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th class="fw-600 py-2">#</th>
                                <th class="fw-600 py-2">Produs</th>
                                <th class="fw-600 py-2 text-end">Cantitate</th>
                                <th class="fw-600 py-2 text-end">Venit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.TopItems.Count; i++)
                            {
                                var item = Model.TopItems[i];
                                <tr>
                                    <td class="text-muted fw-700">@(i + 1)</td>
                                    <td class="fw-600">@item.Name</td>
                                    <td class="text-end">@item.Quantity buc.</td>
                                    <td class="text-end fw-700 text-orange">@item.Revenue.ToString("0.00") RON</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const data = {
    7:  { labels: @Html.Raw(Model.ChartLabels7Json),  orders: @Html.Raw(Model.ChartOrders7Json),  revenue: @Html.Raw(Model.ChartRevenue7Json)  },
    30: { labels: @Html.Raw(Model.ChartLabels30Json), orders: @Html.Raw(Model.ChartOrders30Json), revenue: @Html.Raw(Model.ChartRevenue30Json) }
};
const totals = {
    7:  { orders: @Model.TotalOrders7d,  revenue: @Model.TotalRevenue7d.ToString("0", System.Globalization.CultureInfo.InvariantCulture) },
    30: { orders: @Model.TotalOrders30d, revenue: @Model.TotalRevenue30d.ToString("0", System.Globalization.CultureInfo.InvariantCulture) }
};

const chartOpts = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
        x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 11 } } },
        y: { beginAtZero: true, ticks: { font: { size: 11 } } }
    },
    elements: { point: { radius: 2 } }
};

const ordersChart = new Chart(document.getElementById('ordersChart'), {
    type: 'line',
    data: { labels: data[7].labels, datasets: [{
        data: data[7].orders, borderColor: '#f97316',
        backgroundColor: 'rgba(249,115,22,.1)', borderWidth: 2, fill: true, tension: 0.35
    }] },
    options: chartOpts
});

const revenueChart = new Chart(document.getElementById('revenueChart'), {
    type: 'line',
    data: { labels: data[7].labels, datasets: [{
        data: data[7].revenue, borderColor: '#0f172a',
        backgroundColor: 'rgba(15,23,42,.07)', borderWidth: 2, fill: true, tension: 0.35
    }] },
    options: chartOpts
});

function setPeriod(p) {
    ordersChart.data.labels = data[p].labels;
    ordersChart.data.datasets[0].data = data[p].orders;
    ordersChart.update();

    revenueChart.data.labels = data[p].labels;
    revenueChart.data.datasets[0].data = data[p].revenue;
    revenueChart.update();

    document.getElementById('cardOrders').textContent = totals[p].orders;
    document.getElementById('cardRevenue').textContent = totals[p].revenue + ' RON';

    document.getElementById('btn7').className = p === 7 ? 'btn btn-orange btn-sm active' : 'btn btn-outline-orange btn-sm';
    document.getElementById('btn30').className = p === 30 ? 'btn btn-orange btn-sm active' : 'btn btn-outline-orange btn-sm';
}
</script>
}
