@model EatUp.Models.Restaurant
@{ ViewData["Title"] = "Aplicație în analiză"; }

<div class="auth-page">
    <div class="auth-card text-center" style="max-width:520px;">
        <div style="font-size:3.5rem; margin-bottom:1rem;">⏳</div>
        <h2 class="fw-700 mb-2" style="font-size:1.4rem;">@Model.Name — în așteptarea aprobării</h2>
        <p class="text-muted mb-4" style="font-size:.9rem; line-height:1.6;">
            Aplicația restaurantului tău este în curs de analiză de către echipa EatUp.
            Vei fi notificat prin email imediat ce este aprobată sau respinsă.
        </p>
        @if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="alert alert-danger text-start rounded-3" style="font-size:.875rem;">
                <strong>Motiv respingere:</strong> @Model.RejectionReason
            </div>
        }
        <a asp-controller="Home" asp-action="Index" class="btn btn-orange px-4">Pagina principală</a>
    </div>
</div>
