@model HomeViewModel
@{
    ViewData["Title"] = "EatUp — Comandă mâncare online";

    var categories = new[] { "All", "Pizza", "Sushi", "Salate", "Românesc", "Fast Food", "Asian", "Mexican", "Cafenea", "Grill", "Vegan", "Indian", "Seafood" };

    var categoryGradients = new Dictionary<string, string>
    {
        ["Pizza"]     = "135deg, #ff6b6b 0%, #ff8e53 100%",
        ["Sushi"]     = "135deg, #4ecdc4 0%, #2193b0 100%",
        ["Salate"]    = "135deg, #56ab2f 0%, #a8e063 100%",
        ["Românesc"]  = "135deg, #c94b4b 0%, #8B0000 100%",
        ["Fast Food"] = "135deg, #f7971e 0%, #ff4e50 100%",
        ["Asian"]     = "135deg, #f953c6 0%, #b91d73 100%",
        ["Mexican"]   = "135deg, #f7971e 0%, #ffd200 100%",
        ["Cafenea"]   = "135deg, #6f4e37 0%, #c8a97a 100%",
        ["Grill"]     = "135deg, #ff4e50 0%, #f9d423 100%",
        ["Vegan"]     = "135deg, #11998e 0%, #38ef7d 100%",
        ["Indian"]    = "135deg, #f7971e 0%, #e35d5b 100%",
        ["Seafood"]   = "135deg, #1a6dff 0%, #00d2ff 100%",
    };

    string GradientFor(string cats) {
        var first = (cats ?? "").Split(',')[0].Trim();
        return categoryGradients.TryGetValue(first, out var g) ? g : "135deg, #667eea 0%, #764ba2 100%";
    }

    var mapData = System.Text.Json.JsonSerializer.Serialize(
        Model.Restaurants.Select(r => new { r.Id, r.Name, r.Lat, r.Lng, r.Categories, r.Category, r.IsOpen, r.Logo, r.Rating }),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });

    var cities = new[] { "București", "Craiova" };
    string? activeCity = Model.City;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

<section class="hero-section">
    <div class="container">
        <div class="hero-inner">
            <h1 class="hero-title">
                Comandă mâncare delicioasă<br>
                <span class="text-orange">direct la ușa ta</span>
            </h1>
            <p class="hero-sub">Restaurante de top din România. Livrat rapid.</p>

            <form method="get" asp-controller="Home" asp-action="Index" class="hero-search-form">
                <div class="hero-search-box">
                    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                         fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="search" name="q" value="@Model.Query"
                           class="hero-search-input"
                           placeholder="Caută restaurant sau fel de mâncare..." />
                    <button type="submit" class="btn btn-orange px-4 fw-600">Caută</button>
                </div>
                @if (!string.IsNullOrEmpty(Model.Category) && Model.Category != "All")
                { <input type="hidden" name="category" value="@Model.Category" /> }
                @if (!string.IsNullOrEmpty(Model.City))
                { <input type="hidden" name="city" value="@Model.City" /> }
                @if (Model.Sort != "rating")
                { <input type="hidden" name="sort" value="@Model.Sort" /> }
                @if (Model.OpenNow)
                { <input type="hidden" name="openNow" value="true" /> }
                @if (Model.FreeDelivery)
                { <input type="hidden" name="freeDelivery" value="true" /> }
                @if (Model.MinRating)
                { <input type="hidden" name="minRating" value="true" /> }
            </form>
        </div>
    </div>
</section>

@if (User.Identity?.IsAuthenticated == true && User.FindFirst("Role")?.Value == "Customer")
{
    <section class="py-2 bg-white border-bottom">
        <div class="container">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="text-muted fw-600" style="font-size:.82rem;">📍 Oraș:</span>
                @{
                    var cityHrefAll = Url.Action("Index", "Home", new { q = Model.Query, category = Model.Category, city = "Toate", sort = Model.Sort, openNow = Model.OpenNow, freeDelivery = Model.FreeDelivery, minRating = Model.MinRating });
                    var allCityActive = activeCity == "Toate" || activeCity == null;
                }
                <a href="@cityHrefAll" class="category-pill @(allCityActive ? "active" : "")" style="font-size:.8rem;padding:.3rem .85rem;">Toate</a>
                @foreach (var c in cities)
                {
                    var cityHref = Url.Action("Index", "Home", new { q = Model.Query, category = Model.Category, city = c, sort = Model.Sort, openNow = Model.OpenNow, freeDelivery = Model.FreeDelivery, minRating = Model.MinRating });
                    <a href="@cityHref" class="category-pill @(activeCity == c ? "active" : "")" style="font-size:.8rem;padding:.3rem .85rem;">@c</a>
                }
            </div>
        </div>
    </section>
}

<section class="py-4 bg-white border-bottom">
    <div class="container">
        <div class="category-pills">
            @foreach (var cat in categories)
            {
                var isActive = (cat == "All" && string.IsNullOrEmpty(Model.Category))
                            || string.Equals(Model.Category, cat, StringComparison.OrdinalIgnoreCase);
                var href = Url.Action("Index", "Home", new
                {
                    q = Model.Query,
                    category = cat == "All" ? null : cat,
                    city = Model.City,
                    sort = Model.Sort,
                    openNow = Model.OpenNow,
                    freeDelivery = Model.FreeDelivery,
                    minRating = Model.MinRating
                });
                var emoji = cat switch
                {
                    "All"      => "🍽️", "Pizza"    => "🍕", "Sushi"    => "🍣",
                    "Salate"   => "🥗", "Românesc" => "🇷🇴", "Fast Food"=> "🌯",
                    "Asian"    => "🍜", "Mexican"  => "🌮", "Cafenea"  => "☕",
                    "Grill"    => "🥩", "Vegan"    => "🌱", "Indian"   => "🍛",
                    "Seafood"  => "🐟", _ => "🍴"
                };
                <a href="@href" class="category-pill @(isActive ? "active" : "")">
                    @emoji @cat
                </a>
            }
        </div>
    </div>
</section>

<section class="py-3 bg-white border-bottom">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="text-muted" style="font-size:.85rem; font-weight:500;">Filtre:</span>
                <a href="@Url.Action("Index","Home", new{q=Model.Query,category=Model.Category,city=Model.City,sort=Model.Sort,openNow=!Model.OpenNow,freeDelivery=Model.FreeDelivery,minRating=Model.MinRating})"
                   class="filter-chip @(Model.OpenNow?"active":"")">🟢 Deschis acum</a>
                <a href="@Url.Action("Index","Home", new{q=Model.Query,category=Model.Category,city=Model.City,sort=Model.Sort,openNow=Model.OpenNow,freeDelivery=!Model.FreeDelivery,minRating=Model.MinRating})"
                   class="filter-chip @(Model.FreeDelivery?"active":"")">🚚 Livrare gratuită</a>
                <a href="@Url.Action("Index","Home", new{q=Model.Query,category=Model.Category,city=Model.City,sort=Model.Sort,openNow=Model.OpenNow,freeDelivery=Model.FreeDelivery,minRating=!Model.MinRating})"
                   class="filter-chip @(Model.MinRating?"active":"")">⭐ Rating 4+</a>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted" style="font-size:.85rem; font-weight:500;">Sortare:</span>
                <div class="sort-tabs">
                    @foreach (var (value, label) in new[] {("fastest","Cel mai rapid"),("popular","Populare"),("cheapest","💸 Cel mai ieftin"),("recomandate","✨ Recomandate")})
                    {
                        var sortHref = Url.Action("Index","Home",new{q=Model.Query,category=Model.Category,city=Model.City,sort=value,openNow=Model.OpenNow,freeDelivery=Model.FreeDelivery,minRating=Model.MinRating});
                        @if (value == "recomandate" && User.Identity?.IsAuthenticated != true)
                        {
                            <a href="/account/login" class="sort-tab" title="Autentifică-te pentru recomandări personalizate">✨ Recomandate</a>
                        }
                        else
                        {
                            <a href="@sortHref" class="sort-tab @(Model.Sort==value?"active":"")">@label</a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>


<section class="py-5">
    <div class="container">
        @if (!string.IsNullOrWhiteSpace(Model.Query))
        {
            <p class="text-muted mb-4" style="font-size:.9rem;">
                <strong>@Model.Restaurants.Count</strong> @(Model.Restaurants.Count == 1 ? "rezultat" : "rezultate") pentru „<em>@Model.Query</em>"
            </p>
        }

        <div id="skel-grid" class="row g-4">
            @for (int _s = 0; _s < 6; _s++) {
                <div class="col-12 col-sm-6 col-xl-4"><div class="skeleton-card"></div></div>
            }
        </div>

        @if (Model.Restaurants.Count == 0)
        {
            <div id="real-grid" style="display:none">
                <div class="text-center py-5">
                    <div style="font-size:3.5rem;">🔍</div>
                    <h4 class="fw-700 mt-3 mb-2">Niciun restaurant găsit</h4>
                    <p class="text-muted">Încearcă alte cuvinte cheie sau elimină filtrele active.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-orange mt-3 px-4">
                        Resetează toate filtrele
                    </a>
                </div>
            </div>
        }
        else
        {
            <div id="real-grid" style="display:none" class="row g-4">
                @foreach (var r in Model.Restaurants)
                {
                    <div class="col-12 col-sm-6 col-xl-4">
                        <a href="/restaurants/@r.Id" class="text-decoration-none">
                            <div class="restaurant-card">
                                @{
                                    var cardCats = (string.IsNullOrEmpty(r.Categories) ? r.Category : r.Categories)
                                        .Split(',').Select(c => c.Trim()).Where(c => !string.IsNullOrEmpty(c)).ToList();
                                }
                                <div class="restaurant-cover"
                                     style="background: linear-gradient(@GradientFor(string.IsNullOrEmpty(r.Categories) ? r.Category : r.Categories));">
                                    @if (!string.IsNullOrEmpty(r.CoverImage))
                                    {
                                        <img src="@r.CoverImage" alt="" class="cover-img" />
                                    }
                                    <div class="restaurant-logo-badge">
                                        @if (!string.IsNullOrEmpty(r.Logo))
                                        { <img src="@r.Logo" alt="" /> }
                                        else
                                        { <span class="fw-700 text-white">@r.Name[0]</span> }
                                    </div>
                                    <span class="status-badge @(r.IsOpen ? "open" : "closed")">
                                        @(r.IsOpen ? "Deschis" : "Închis")
                                    </span>
                                    <span class="category-tag">@cardCats.FirstOrDefault()</span>
                                </div>
                                <div class="restaurant-card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <h5 class="restaurant-card-name">@r.Name</h5>
                                        <span class="rating-pill">★ @r.Rating.ToString("0.0")</span>
                                    </div>
                                    <p class="restaurant-card-desc">
                                        @(r.Description.Length > 72 ? r.Description[..72] + "…" : r.Description)
                                    </p>
                                    <div class="restaurant-card-meta">
                                        <span title="Timp estimat livrare">⏱ @r.EstimatedDeliveryTime min</span>
                                        <span>·</span>
                                        <span>@(r.DeliveryFee == 0 ? "Livrare gratuită 🎉" : r.DeliveryFee.ToString("0") + " RON livrare")</span>
                                        <span>·</span>
                                        <span class="text-muted">@r.TotalReviews recenzii</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</section>

@if (Model.Restaurants.Count > 0)
{
    <section class="py-5 bg-white border-top">
        <div class="container">
            <h3 class="fw-700 mb-3" style="font-size:1.2rem;">📍 Restaurante pe hartă</h3>
            <div id="home-map"></div>
        </div>
    </section>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const restaurants = @Html.Raw(mapData);
        if (restaurants.length > 0) {
            const map = L.map('home-map').setView([45.9, 24.9], 7);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© <a href="https://openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            restaurants.forEach(r => {
                const inner = r.logo
                    ? `<img src="${r.logo}" alt=""
                            style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;">`
                    : `<div style="width:100%;height:100%;border-radius:50%;
                                background:#f97316;display:flex;align-items:center;justify-content:center;">
                           <span style="color:#fff;font-weight:800;font-size:18px;line-height:1;">
                               ${r.name[0]}
                           </span>
                       </div>`;

                const markerHtml =
                    `<div style="position:relative;width:48px;height:48px;cursor:pointer;">` +
                    `<div style="width:48px;height:48px;border-radius:50%;border:3px solid #f97316;` +
                    `box-shadow:0 3px 14px rgba(0,0,0,.28);overflow:hidden;background:#fff;">` +
                    inner + `</div>` +
                    `<div style="position:absolute;bottom:-9px;left:50%;transform:translateX(-50%);` +
                    `width:0;height:0;border-left:7px solid transparent;border-right:7px solid transparent;` +
                    `border-top:10px solid #f97316;"></div></div>`;

                const icon = L.divIcon({
                    html: markerHtml,
                    className: '',
                    iconSize: [48, 58],
                    iconAnchor: [24, 58]
                });

                const popupHtml =
                    `<div style="font-family:Inter,sans-serif;min-width:150px;padding:2px 0;">` +
                    `<strong style="font-size:.9rem;">${r.name}</strong><br>` +
                    `<span style="color:#f97316;font-size:.8rem;font-weight:600;">★ ${r.rating.toFixed(1)}</span>` +
                    `<span style="font-size:.75rem;color:#64748b;margin-left:5px;">${r.category}</span><br>` +
                    `<a href="/restaurants/${r.id}"` +
                    ` style="display:inline-block;margin-top:7px;padding:4px 14px;` +
                    `background:#f97316;color:#fff;border-radius:8px;` +
                    `text-decoration:none;font-size:.78rem;font-weight:600;">` +
                    `Vezi meniul →</a></div>`;

                const marker = L.marker([r.lat, r.lng], { icon }).addTo(map);

                marker.on('mouseover', () => {
                    L.popup({ offset: [0, -58], closeButton: false, autoClose: false, maxWidth: 220 })
                        .setLatLng([r.lat, r.lng])
                        .setContent(popupHtml)
                        .openOn(map);
                });
                marker.on('mouseout', () => map.closePopup());
                marker.on('click', () => { window.location.href = '/restaurants/' + r.id; });
            });

            const bounds = L.latLngBounds(restaurants.map(r => [r.lat, r.lng]));
            map.fitBounds(bounds.pad(0.2));
        }
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            setTimeout(function () {
                const skel = document.getElementById('skel-grid');
                const real = document.getElementById('real-grid');
                if (skel) skel.style.display = 'none';
                if (real) real.style.display = '';
            }, 400);
        });
    </script>
}
