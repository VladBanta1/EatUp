@model List<EatUp.Models.ContactMessage>
@{ ViewData["Title"] = "Mesaje Contact"; }

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-800 mb-0" style="font-size:1.5rem;">
            Mesaje Contact
            @if (Model.Any(m => !m.IsRead))
            {
                <span class="badge bg-danger ms-2" style="font-size:.75rem;vertical-align:middle;">
                    @Model.Count(m => !m.IsRead) necitite
                </span>
            }
        </h2>
        <span class="text-muted small">@Model.Count mesaje total</span>
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <div style="font-size:3rem;">📭</div>
            <h5 class="fw-700 mt-3">Nu există mesaje</h5>
            <p class="text-muted">Niciun mesaj de contact primit încă.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">
            <table class="table table-hover mb-0" id="messagesTable">
                <thead style="background:var(--gray-50);">
                    <tr>
                        <th class="px-4 py-3 fw-600 small">Expeditor</th>
                        <th class="px-3 py-3 fw-600 small">Subiect</th>
                        <th class="px-3 py-3 fw-600 small">Data</th>
                        <th class="px-3 py-3 fw-600 small">Status</th>
                        <th class="px-3 py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr class="msg-row @(!m.IsRead ? "table-warning" : "")" data-id="@m.Id" style="cursor:pointer;">
                            <td class="px-4 py-3">
                                <div class="fw-600 small">@m.Name</div>
                                <div class="text-muted" style="font-size:.75rem;">@m.Email</div>
                            </td>
                            <td class="px-3 py-3 fw-500 small">@m.Subject</td>
                            <td class="px-3 py-3 text-muted small">
                                @m.SentAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm", new System.Globalization.CultureInfo("ro-RO"))
                            </td>
                            <td class="px-3 py-3" id="status-cell-@m.Id">
                                @if (m.IsReplied)
                                {
                                    <span class="badge bg-success" style="font-size:.7rem;">Răspuns trimis</span>
                                }
                                else if (m.IsRead)
                                {
                                    <span class="badge bg-secondary" style="font-size:.7rem;">Citit</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger" style="font-size:.7rem;">Nou</span>
                                }
                            </td>
                            <td class="px-3 py-3 text-end" style="white-space:nowrap;">
                                <button class="btn btn-sm btn-outline-secondary me-1" style="font-size:.75rem;border-radius:8px;"
                                        onclick="toggleMsg(event, @m.Id)">
                                    Detalii
                                </button>
                                <button class="btn btn-sm btn-outline-orange fw-600" style="font-size:.75rem;border-radius:8px;"
                                        onclick="openReply(event, @m.Id)">
                                    Răspunde
                                </button>
                            </td>
                        </tr>
                        <tr class="msg-detail d-none" id="detail-@m.Id">
                            <td colspan="5" class="px-4 pb-3 pt-0">
                                <div class="p-3" style="background:#f8f9fa;border-radius:10px;">
                                    <p class="mb-2 small text-muted fw-600">MESAJ:</p>
                                    <p class="mb-3" style="white-space:pre-wrap;font-size:.9rem;">@m.Message</p>
                                    @if (!m.IsRead)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary mark-read-btn"
                                                style="font-size:.8rem;border-radius:8px;"
                                                data-id="@m.Id">
                                            Marchează ca citit
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

<div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:16px;overflow:hidden;">
            <div class="modal-header border-0 px-4 pt-4 pb-2" style="background:#f8fafc;">
                <div>
                    <h5 class="modal-title fw-700 mb-0" style="font-size:1rem;" id="replyModalTitle">Răspuns</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Închide"></button>
            </div>
            <div class="modal-body px-4 py-3">

                <div class="mb-3">
                    <label class="fw-600 small mb-1 d-block">Subiect</label>
                    <input type="text" id="replySubject" class="form-control" style="border-radius:10px;font-size:.9rem;" />
                </div>

                <div class="mb-3">
                    <label class="fw-600 small mb-1 d-block text-muted">Mesaj original</label>
                    <div id="quotedMsg" class="p-3"
                         style="background:#f1f5f9;border-left:3px solid #cbd5e1;border-radius:8px;
                                font-size:.85rem;color:#64748b;white-space:pre-wrap;max-height:140px;overflow-y:auto;">
                    </div>
                </div>

                <div class="mb-1">
                    <label class="fw-600 small mb-1 d-block">Răspunsul tău</label>
                    <textarea id="replyBody" rows="6" class="form-control"
                              placeholder="Scrie răspunsul tău aici..."
                              style="border-radius:10px;font-size:.9rem;resize:vertical;"></textarea>
                </div>

            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-2 gap-2 justify-content-end">
                <button type="button" class="btn btn-outline-secondary fw-600 px-4"
                        style="border-radius:10px;" data-bs-dismiss="modal">Anulează</button>
                <button type="button" class="btn btn-orange fw-700 px-5"
                        style="border-radius:10px;" id="sendReplyBtn">
                    Trimite răspunsul
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// serialize all message data to a JS map once; avoids fragile HTML attribute escaping when message content contains quotes or special characters
const messageData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.ToDictionary(
        m => m.Id,
        m => new { name = m.Name, email = m.Email, subject = m.Subject, message = m.Message }
    )
));

let _replyMsgId = null;
let _replyEmail  = '';

function toggleMsg(e, id) {
    e.stopPropagation();
    document.getElementById('detail-' + id).classList.toggle('d-none');
}

document.querySelectorAll('.msg-row').forEach(row => {
    row.addEventListener('click', function() {
        document.getElementById('detail-' + this.dataset.id).classList.toggle('d-none');
    });
});

document.querySelectorAll('.mark-read-btn').forEach(btn => {
    btn.addEventListener('click', async function(e) {
        e.stopPropagation();
        const id = this.dataset.id;
        const token = document.querySelector('meta[name="request-verification-token"]')?.content;
        const res = await fetch(`/Admin/MarkAsRead?id=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token || '' }
        });
        if (res.ok) {
            const row = document.querySelector(`.msg-row[data-id="${id}"]`);
            if (row) row.classList.remove('table-warning');
            const statusCell = document.getElementById('status-cell-' + id);
            if (statusCell) statusCell.innerHTML = '<span class="badge bg-secondary" style="font-size:.7rem;">Citit</span>';
            this.remove();
            _updateUnreadBadge();
        }
    });
});

function _updateUnreadBadge() {
    const unread = document.querySelectorAll('.msg-row.table-warning').length;
    const badge  = document.querySelector('h2 .badge.bg-danger');
    if (unread === 0 && badge) badge.remove();
    else if (badge) badge.textContent = unread + ' necitite';
}

function openReply(e, id) {
    e.stopPropagation();
    const data = messageData[id];
    if (!data) return;
    _replyMsgId = id;
    _replyEmail  = data.email;
    document.getElementById('replyModalTitle').textContent = `Răspuns către ${data.name} <${data.email}>`;
    document.getElementById('replySubject').value = `Re: ${data.subject}`;
    document.getElementById('quotedMsg').textContent = data.message;
    document.getElementById('replyBody').value = '';
    new bootstrap.Modal(document.getElementById('replyModal')).show();
}

document.getElementById('sendReplyBtn').addEventListener('click', async function() {
    const body = document.getElementById('replyBody').value.trim();
    if (!body) { document.getElementById('replyBody').focus(); return; }

    this.disabled = true;
    this.textContent = 'Se trimite…';

    const token = document.querySelector('meta[name="request-verification-token"]')?.content;
    const res = await fetch(`/Admin/MarkAsReplied?id=${_replyMsgId}`, {
        method: 'POST',
        headers: { 'RequestVerificationToken': token || '' }
    });

    if (res.ok) {
        bootstrap.Modal.getInstance(document.getElementById('replyModal')).hide();

        const row = document.querySelector(`.msg-row[data-id="${_replyMsgId}"]`);
        if (row) {
            row.classList.remove('table-warning');
            const statusCell = document.getElementById('status-cell-' + _replyMsgId);
            if (statusCell) statusCell.innerHTML = '<span class="badge bg-success" style="font-size:.7rem;">Răspuns trimis</span>';
        }

        _updateUnreadBadge();

        if (typeof showToast === 'function')
            showToast(`Răspuns trimis către ${_replyEmail}`, 'success');
    }

    this.disabled = false;
    this.textContent = 'Trimite răspunsul';
});
</script>
}
