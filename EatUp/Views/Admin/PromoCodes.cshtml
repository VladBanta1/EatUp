@model List<EatUp.Models.PromoCode>
@using EatUp.Models
@{ ViewData["Title"] = "Coduri Promoționale"; }

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-700 mb-0" style="font-size:1.5rem;">Coduri Promoționale</h2>
        <button class="btn btn-orange" data-bs-toggle="modal" data-bs-target="#createModal">
            + Cod nou
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="cart-section text-center py-5">
            <div style="font-size:2.5rem;">🎟️</div>
            <div class="fw-600 mt-2 mb-1">Niciun cod promoțional</div>
            <div class="text-muted small">Creează primul cod pentru clienții tăi.</div>
        </div>
    }
    else
    {
        <div class="cart-section">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.88rem;">
                    <thead style="background:#f8fafc; border-bottom:2px solid #e2e8f0;">
                        <tr>
                            <th class="fw-600 py-3">Cod</th>
                            <th class="fw-600 py-3">Descriere</th>
                            <th class="fw-600 py-3">Tip</th>
                            <th class="fw-600 py-3">Valoare</th>
                            <th class="fw-600 py-3">Min. cmd.</th>
                            <th class="fw-600 py-3">Utilizări</th>
                            <th class="fw-600 py-3">Expiră</th>
                            <th class="fw-600 py-3">Status</th>
                            <th class="fw-600 py-3 text-end">Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            var expired = c.ExpiresAt.HasValue && c.ExpiresAt < DateTime.UtcNow;
                            <tr>
                                <td><span class="fw-700 font-monospace">@c.Code</span></td>
                                <td class="text-muted">@(c.Description ?? "—")</td>
                                <td>
                                    @if (c.DiscountType == DiscountType.Percentage)
                                    {
                                        <span class="badge bg-primary" style="font-size:.72rem;">%</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success" style="font-size:.72rem;">RON</span>
                                    }
                                </td>
                                <td class="fw-700 text-orange">
                                    @if (c.DiscountType == DiscountType.Percentage)
                                    { @c.DiscountValue <text>%</text> }
                                    else
                                    { @c.DiscountValue.ToString("0.00") <text> RON</text> }
                                </td>
                                <td>@(c.MinOrderAmount > 0 ? c.MinOrderAmount.ToString("0") + " RON" : "—")</td>
                                <td>
                                    @c.UsedCount
                                    @if (c.MaxUses > 0)
                                    {
                                        <span class="text-muted">/ @c.MaxUses</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">/ ∞</span>
                                    }
                                </td>
                                <td class="@(expired ? "text-danger" : "text-muted")">
                                    @(c.ExpiresAt.HasValue ? c.ExpiresAt.Value.ToLocalTime().ToString("dd MMM yyyy") : "—")
                                    @if (expired) { <small>(Expirat)</small> }
                                </td>
                                <td>
                                    @if (c.IsActive && !expired)
                                    {
                                        <span class="badge bg-success">Activ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactiv</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="TogglePromoCode" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn btn-sm @(c.IsActive ? "btn-outline-secondary" : "btn-outline-success")">
                                            @(c.IsActive ? "Dezactivează" : "Activează")
                                        </button>
                                    </form>
                                    <form asp-action="DeletePromoCode" method="post" style="display:inline;"
                                          onsubmit="return confirm('Ești sigur că vrei să ștergi codul @c.Code?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Șterge</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:500px;">
        <div class="modal-content" style="border-radius:16px; border:none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-700">Cod promoțional nou</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="CreatePromoCode" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="fw-600 small mb-1 d-block">Cod *</label>
                        <input type="text" name="Code" class="form-control font-monospace fw-700"
                               placeholder="ex: SUMMER20" required maxlength="50"
                               style="text-transform:uppercase;" />
                        <div class="text-muted small mt-1">Va fi salvat cu majuscule.</div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-600 small mb-1 d-block">Descriere (opțional)</label>
                        <input type="text" name="Description" class="form-control"
                               placeholder="ex: 20% reducere vara aceasta" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="fw-600 small mb-1 d-block">Tip reducere *</label>
                            <select name="DiscountType" class="form-select" id="discTypeSelect" onchange="updateValueLabel()">
                                <option value="0">Procentuală (%)</option>
                                <option value="1">Fixă (RON)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="fw-600 small mb-1 d-block" id="valueLabel">Valoare (%) *</label>
                            <input type="number" name="DiscountValue" class="form-control"
                                   min="0.01" step="0.01" required />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="fw-600 small mb-1 d-block">Comandă minimă (RON)</label>
                            <input type="number" name="MinOrderAmount" class="form-control"
                                   min="0" step="0.01" value="0" />
                        </div>
                        <div class="col-6">
                            <label class="fw-600 small mb-1 d-block">Max. utilizări (0=nelimitat)</label>
                            <input type="number" name="MaxUses" class="form-control"
                                   min="0" step="1" value="0" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-600 small mb-1 d-block">Dată expirare (opțional)</label>
                        <input type="datetime-local" name="ExpiresAt" class="form-control" />
                    </div>
                    <div class="mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true"
                                   id="isActiveCheck" checked />
                            <label class="form-check-label fw-600 small" for="isActiveCheck">Activ imediat</label>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Anulează</button>
                        <button type="submit" class="btn btn-orange fw-600 px-4">Creează</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function updateValueLabel() {
    const t = document.getElementById('discTypeSelect').value;
    document.getElementById('valueLabel').textContent = t === '0' ? 'Valoare (%) *' : 'Valoare (RON) *';
}
document.querySelector('input[name="Code"]').addEventListener('input', function() {
    this.value = this.value.toUpperCase();
});
</script>
}
