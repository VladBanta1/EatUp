@model List<EatUp.Models.User>
@using EatUp.Models
@{ ViewData["Title"] = "Utilizatori"; }

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-700 mb-0" style="font-size:1.5rem;">Utilizatori</h2>
        <span class="text-muted small">@Model.Count utilizatori găsiți</span>
    </div>

    <div class="mb-3">
        <form asp-action="Users" method="get" class="d-flex gap-2" style="max-width:420px;">
            <input type="text" name="q" value="@ViewBag.Q" class="form-control"
                   placeholder="Caută după nume sau email…" />
            <button type="submit" class="btn btn-orange px-3">Caută</button>
            @if (!string.IsNullOrEmpty((string?)ViewBag.Q))
            {
                <a asp-action="Users" class="btn btn-light">×</a>
            }
        </form>
    </div>

    <div class="cart-section">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:.88rem;">
                <thead style="background:#f8fafc; border-bottom:2px solid #e2e8f0;">
                    <tr>
                        <th class="fw-600 py-3">Utilizator</th>
                        <th class="fw-600 py-3">Rol</th>
                        <th class="fw-600 py-3">Telefon</th>
                        <th class="fw-600 py-3">Înregistrat</th>
                        <th class="fw-600 py-3">Status</th>
                        <th class="fw-600 py-3 text-end">Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(u.Avatar))
                                    {
                                        <img src="@u.Avatar" style="width:32px;height:32px;border-radius:50%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div style="width:32px;height:32px;border-radius:50%;background:var(--gray-200);
                                                    display:flex;align-items:center;justify-content:center;
                                                    font-size:.8rem;font-weight:700;color:var(--gray-600);">
                                            @(u.Name.Length > 0 ? u.Name[0].ToString().ToUpper() : "U")
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-600">@u.Name</div>
                                        <div class="text-muted" style="font-size:.78rem;">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(u.Role == UserRole.Admin ? "bg-dark" : u.Role == UserRole.Restaurant ? "bg-primary" : "bg-secondary")"
                                      style="font-size:.72rem;">
                                    @u.Role
                                </span>
                            </td>
                            <td class="text-muted">@(u.Phone ?? "—")</td>
                            <td class="text-muted">@u.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>
                                @if (u.IsBlocked)
                                {
                                    <span class="badge bg-danger">Blocat</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Activ</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (u.Role != UserRole.Admin)
                                {
                                    <form asp-action="BlockUser" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit"
                                                class="btn btn-sm @(u.IsBlocked ? "btn-outline-success" : "btn-outline-danger")">
                                            @(u.IsBlocked ? "Deblochează" : "Blochează")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-4 text-muted">Niciun utilizator găsit.</div>
        }
    </div>
</div>
