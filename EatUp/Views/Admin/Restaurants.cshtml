@using EatUp.Models
@using EatUp.ViewModels
@{
    ViewData["Title"] = "Restaurante";
    string tab = ViewBag.Tab ?? "pending";
    int pendingCount = ViewBag.PendingCount ?? 0;
    var pending = (List<Restaurant>)ViewBag.PendingRestaurants;
    var all = (List<Restaurant>)ViewBag.AllRestaurants;
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-700 mb-0" style="font-size:1.5rem;">Restaurante</h2>
    </div>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(tab == "pending" ? "active" : "")"
               asp-action="Restaurants" asp-route-tab="pending">
                Aplicații în așteptare
                @if (pendingCount > 0)
                {
                    <span class="badge ms-1" style="background:var(--orange); font-size:.7em;">@pendingCount</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(tab == "all" ? "active" : "")"
               asp-action="Restaurants" asp-route-tab="all">
                Toate restaurantele
            </a>
        </li>
    </ul>

    @if (tab == "pending")
    {
        @if (!pending.Any())
        {
            <div class="cart-section text-center py-5">
                <div style="font-size:2.5rem;">✅</div>
                <div class="fw-600 mt-2">Nicio aplicație în așteptare</div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var r in pending)
                {
                    List<DaySchedule>? hours = null;
                    try {
                        if (r.OpeningHoursJson != null) {
                            var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, DaySchedule>>(
                                r.OpeningHoursJson,
                                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                            if (dict != null)
                                hours = dict.Select(kv => new DaySchedule {
                                    Day = kv.Key, IsClosed = kv.Value.IsClosed,
                                    Open = kv.Value.Open, Close = kv.Value.Close
                                }).ToList();
                        }
                    } catch {}

                    <div class="col-lg-6">
                        <div class="card-eatup p-4">
                            <div class="d-flex gap-3 align-items-start mb-3">
                                @if (!string.IsNullOrEmpty(r.Logo))
                                {
                                    <img src="@r.Logo" alt="logo"
                                         style="width:64px;height:64px;border-radius:12px;object-fit:cover;flex-shrink:0;" />
                                }
                                else
                                {
                                    <div style="width:64px;height:64px;border-radius:12px;background:var(--gray-100);
                                                display:flex;align-items:center;justify-content:center;
                                                font-size:1.75rem;flex-shrink:0;">🍽️</div>
                                }
                                <div>
                                    <div class="fw-700" style="font-size:1.05rem;">@r.Name</div>
                                    <div class="text-muted small">@r.Category &nbsp;·&nbsp; @r.Address</div>
                                    <div class="text-muted small">Proprietar: @r.User.Name (@r.User.Email)</div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(r.Description))
                            {
                                <p class="text-muted small mb-3">@r.Description</p>
                            }

                            <div class="row g-2 mb-3 text-center" style="font-size:.82rem;">
                                <div class="col-4">
                                    <div class="p-2 rounded-3" style="background:var(--gray-100);">
                                        <div class="fw-700 text-orange">@r.DeliveryFee RON</div>
                                        <div class="text-muted">Livrare</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="p-2 rounded-3" style="background:var(--gray-100);">
                                        <div class="fw-700 text-orange">@r.MinOrderAmount RON</div>
                                        <div class="text-muted">Min. comandă</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="p-2 rounded-3" style="background:var(--gray-100);">
                                        <div class="fw-700 text-orange">@r.EstimatedDeliveryTime min</div>
                                        <div class="text-muted">Livrare</div>
                                    </div>
                                </div>
                            </div>

                            @if (hours != null)
                            {
                                <div class="mb-3">
                                    <div class="fw-600 small mb-1">Program</div>
                                    <div class="row g-1" style="font-size:.78rem;">
                                        @foreach (var h in hours)
                                        {
                                            <div class="col-6">
                                                <span class="fw-500">@h.Day.Substring(0,3):</span>
                                                @if (h.IsClosed) { <span class="text-danger">Închis</span> }
                                                else { <span class="text-muted">@h.Open – @h.Close</span> }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <form asp-action="ApproveRestaurant" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-orange fw-600">Aprobă</button>
                                </form>
                                <button class="btn btn-outline-danger fw-600"
                                        onclick="openRejectRestaurant(@r.Id, '@Html.Raw(r.Name.Replace("'","\\'" ))')">
                                    Respinge
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="mb-3">
            <input type="text" id="searchInput" class="form-control" style="max-width:360px;"
                   placeholder="Caută după nume, categorie…" oninput="filterTable()" />
        </div>
        <div class="cart-section">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="restTable" style="font-size:.88rem;">
                    <thead style="background:#f8fafc; border-bottom:2px solid #e2e8f0;">
                        <tr>
                            <th class="fw-600 py-3">Restaurant</th>
                            <th class="fw-600 py-3">Categorie</th>
                            <th class="fw-600 py-3">Rating</th>
                            <th class="fw-600 py-3">Status</th>
                            <th class="fw-600 py-3 text-end">Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in all)
                        {
                            <tr>
                                <td>
                                    <div class="fw-600">@r.Name</div>
                                    <div class="text-muted" style="font-size:.78rem;">@r.User.Email</div>
                                </td>
                                <td>@r.Category</td>
                                <td>
                                    @if (r.TotalReviews > 0)
                                    {
                                        <span class="fw-600">@r.Rating.ToString("0.0") ★</span>
                                        <span class="text-muted small ms-1">(@r.TotalReviews)</span>
                                    }
                                    else { <span class="text-muted small">—</span> }
                                </td>
                                <td>
                                    @if (r.IsBlocked)
                                    {
                                        <span class="badge bg-danger">Blocat</span>
                                    }
                                    else if (r.IsApproved)
                                    {
                                        <span class="badge bg-success">Aprobat</span>
                                    }
                                    else if (r.RejectionReason != null)
                                    {
                                        <span class="badge bg-secondary">Respins</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#fbbf24;color:#92400e;">În așteptare</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="BlockRestaurant" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit"
                                                class="btn btn-sm @(r.IsBlocked ? "btn-outline-success" : "btn-outline-danger")">
                                            @(r.IsBlocked ? "Deblochează" : "Blochează")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="rejectRestModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:440px;">
        <div class="modal-content" style="border-radius:16px; border:none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-700">Respinge aplicația</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="rejectRestName"></p>
                <form id="rejectRestForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="rejectRestId" />
                    <div class="mb-3">
                        <label class="fw-600 small mb-1 d-block">Motiv *</label>
                        <textarea name="reason" rows="3" class="form-control" required
                                  placeholder="Explică motivul respingerii…"
                                  style="resize:none; border-radius:10px;"></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger fw-600 w-100">Respinge</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openRejectRestaurant(id, name) {
    document.getElementById('rejectRestId').value = id;
    document.getElementById('rejectRestName').textContent = `Restaurant: ${name}`;
    document.getElementById('rejectRestForm').action = `/Admin/RejectRestaurant?id=${id}`;
    new bootstrap.Modal(document.getElementById('rejectRestModal')).show();
}
function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#restTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
</script>
}
