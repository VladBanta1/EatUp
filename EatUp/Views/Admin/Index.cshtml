@model EatUp.ViewModels.AdminDashboardViewModel
@using EatUp.Models
@{ ViewData["Title"] = "Admin Dashboard"; }

@functions {
    static string StatusLabel(OrderStatus s) => s switch {
        OrderStatus.Pending        => "În așteptare",
        OrderStatus.Accepted       => "Acceptată",
        OrderStatus.Preparing      => "Se prepară",
        OrderStatus.ReadyForPickup => "Gata de ridicare",
        OrderStatus.OutForDelivery => "În drum spre tine",
        OrderStatus.Delivered      => "Livrată",
        OrderStatus.Rejected       => "Respinsă",
        OrderStatus.Cancelled      => "Anulată",
        _ => s.ToString()
    };
    static string StatusClass(OrderStatus s) => s switch {
        OrderStatus.Pending        => "status-pending",
        OrderStatus.Accepted       => "status-accepted",
        OrderStatus.Preparing      => "status-preparing",
        OrderStatus.ReadyForPickup => "status-ready",
        OrderStatus.OutForDelivery => "status-delivery",
        OrderStatus.Delivered      => "status-delivered",
        OrderStatus.Rejected       => "status-rejected",
        OrderStatus.Cancelled      => "status-cancelled",
        _ => ""
    };
}

<div class="container py-5">
    <h1 class="fw-700 mb-4" style="font-size:1.75rem;">
        Admin Dashboard
        <span class="badge ms-2" style="background:var(--orange); font-size:.55em; vertical-align:middle;">Admin</span>
    </h1>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-2">
            <div class="card-eatup p-3 text-center">
                <div style="font-size:1.6rem; font-weight:800; color:var(--orange);">@Model.TotalUsers</div>
                <div class="text-muted" style="font-size:.8rem;">Utilizatori</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card-eatup p-3 text-center">
                <div style="font-size:1.6rem; font-weight:800; color:var(--orange);">@Model.TotalRestaurants</div>
                <div class="text-muted" style="font-size:.8rem;">Restaurante</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card-eatup p-3 text-center">
                <div style="font-size:1.6rem; font-weight:800; color:var(--orange);">@Model.OrdersToday</div>
                <div class="text-muted" style="font-size:.8rem;">Comenzi azi</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card-eatup p-3 text-center">
                <div style="font-size:1.3rem; font-weight:800; color:var(--orange);">@Model.RevenueToday.ToString("0.00") RON</div>
                <div class="text-muted" style="font-size:.8rem;">Venit platformă azi</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <a asp-action="Restaurants" class="text-decoration-none">
                <div class="card-eatup p-3 text-center @(Model.PendingRestaurants > 0 ? "border-orange" : "")">
                    <div style="font-size:1.6rem; font-weight:800; color:var(--orange);">@Model.PendingRestaurants</div>
                    <div class="text-muted" style="font-size:.8rem;">Rest. în așteptare</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-2">
            <a asp-action="ChangeRequests" class="text-decoration-none">
                <div class="card-eatup p-3 text-center @(Model.PendingChangeRequests > 0 ? "border-orange" : "")">
                    <div style="font-size:1.6rem; font-weight:800; color:var(--orange);">@Model.PendingChangeRequests</div>
                    <div class="text-muted" style="font-size:.8rem;">Cereri meniu</div>
                </div>
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card-eatup p-4">
                <h6 class="fw-700 mb-3">Comenzi per zi (ultimele 30 zile)</h6>
                <div style="height:220px;"><canvas id="ordersChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card-eatup p-4">
                <h6 class="fw-700 mb-3">Comision platformă/zi — RON (ultimele 30 zile)</h6>
                <div style="height:220px;"><canvas id="revenueChart"></canvas></div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <a asp-action="Restaurants" class="text-decoration-none">
                <div class="card-eatup p-4 h-100">
                    <div style="font-size:1.5rem; margin-bottom:.5rem;">🍽️</div>
                    <div class="fw-600">Restaurante</div>
                    <div class="text-muted small">Aprobă sau respinge aplicații</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Users" class="text-decoration-none">
                <div class="card-eatup p-4 h-100">
                    <div style="font-size:1.5rem; margin-bottom:.5rem;">👤</div>
                    <div class="fw-600">Utilizatori</div>
                    <div class="text-muted small">Gestionează utilizatorii</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Orders" class="text-decoration-none">
                <div class="card-eatup p-4 h-100">
                    <div style="font-size:1.5rem; margin-bottom:.5rem;">📦</div>
                    <div class="fw-600">Comenzi</div>
                    <div class="text-muted small">Toate comenzile platformei</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="ChangeRequests" class="text-decoration-none">
                <div class="card-eatup p-4 h-100">
                    <div style="font-size:1.5rem; margin-bottom:.5rem;">📋</div>
                    <div class="fw-600">Cereri meniu</div>
                    <div class="text-muted small">Modificări de meniu</div>
                </div>
            </a>
        </div>
    </div>

    <div class="card-eatup p-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 class="fw-700 mb-0">Ultimele 10 comenzi</h6>
            <a asp-action="Orders" class="text-orange small fw-600 text-decoration-none">Vezi toate →</a>
        </div>
        @if (!Model.RecentOrders.Any())
        {
            <div class="text-muted small text-center py-3">Nicio comandă încă.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.88rem;">
                    <thead style="background:#f8fafc;">
                        <tr>
                            <th class="fw-600 py-2">#</th>
                            <th class="fw-600 py-2">Client</th>
                            <th class="fw-600 py-2">Restaurant</th>
                            <th class="fw-600 py-2">Data</th>
                            <th class="fw-600 py-2">Status</th>
                            <th class="fw-600 py-2 text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.RecentOrders)
                        {
                            <tr>
                                <td class="text-muted">#@o.Id</td>
                                <td class="fw-500">@o.Customer.Name</td>
                                <td>@o.Restaurant.Name</td>
                                <td class="text-muted">@o.CreatedAt.ToLocalTime().ToString("dd MMM · HH:mm")</td>
                                <td><span class="order-status-pill @StatusClass(o.Status)">@StatusLabel(o.Status)</span></td>
                                <td class="text-end fw-700 text-orange">@o.Total.ToString("0.00") RON</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const labels  = @Html.Raw(Model.ChartLabelsJson);
const ordersCt = @Html.Raw(Model.ChartOrdersJson);
const revenueCt = @Html.Raw(Model.ChartRevenueJson);

const chartDefaults = {
    type: 'line',
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 11 } } },
            y: { beginAtZero: true, ticks: { font: { size: 11 } } }
        },
        elements: { point: { radius: 2 } }
    }
};

new Chart(document.getElementById('ordersChart'), {
    ...chartDefaults,
    data: {
        labels,
        datasets: [{
            data: ordersCt,
            borderColor: '#f97316',
            backgroundColor: 'rgba(249,115,22,.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.35
        }]
    }
});

new Chart(document.getElementById('revenueChart'), {
    ...chartDefaults,
    data: {
        labels,
        datasets: [{
            data: revenueCt,
            borderColor: '#0f172a',
            backgroundColor: 'rgba(15,23,42,.07)',
            borderWidth: 2,
            fill: true,
            tension: 0.35
        }]
    }
});
</script>
}
