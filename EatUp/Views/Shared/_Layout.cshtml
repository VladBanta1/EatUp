@inject EatUp.Data.ApplicationDbContext _db
@{
    var role = User.FindFirst("Role")?.Value;
    int unreadMessages = role == "Admin" ? _db.ContactMessages.Count(m => !m.IsRead) : 0;
    var userName = User.Identity?.Name ?? "";
    var avatar = User.FindFirst("Avatar")?.Value;
    var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
    var initials = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction     = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool IsActive(string ctrl, string? action = null) =>
        string.Equals(currentController, ctrl, StringComparison.OrdinalIgnoreCase) &&
        (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));
    int restaurantId = 0;
    if (role == "Restaurant")
    {
        if (int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out int _ruid))
            restaurantId = _db.Restaurants.Where(r => r.UserId == _ruid).Select(r => r.Id).FirstOrDefault();
    }
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EatUp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/eatup.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    @if (role == "Restaurant" && restaurantId > 0)
    {
        <style>
            @@keyframes eatupSlideIn {
                from { transform: translateY(28px) scale(.96); opacity: 0; }
                to   { transform: translateY(0)    scale(1);   opacity: 1; }
            }
            #orderNotifPopup { animation: eatupSlideIn .35s cubic-bezier(.22,1,.36,1) both; }
        </style>
    }
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
</head>
<body>

