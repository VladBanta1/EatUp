                Închide
            </button>
        </div>
    </div>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    function showToast(message, type = 'success') {
        const bg = type === 'success' ? '#0f172a' : (type === 'error' ? '#dc2626' : '#f97316');
        const id = 'toast-' + Date.now();
        const html = `<div id="${id}" class="toast align-items-center text-white border-0 show mb-2"
                           style="background:${bg};border-radius:12px;min-width:260px;" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-500">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>`;
        document.getElementById('toastContainer').insertAdjacentHTML('beforeend', html);
        setTimeout(() => { const el = document.getElementById(id); if (el) el.remove(); }, 4000);
    }
    @if (TempData["Success"] != null) { <text>showToast('@Html.Raw(TempData["Success"])');</text> }
    @if (TempData["Error"] != null) { <text>showToast('@Html.Raw(TempData["Error"])', 'error');</text> }

        // sessionStorage bridges toast messages across client-side redirects (e.g. after order placement)
    const _pendingToast = sessionStorage.getItem('eatup_toast');
    if (_pendingToast) {
        try {
            const t = JSON.parse(_pendingToast);
            sessionStorage.removeItem('eatup_toast');
            setTimeout(() => showToast(t.msg, t.type || 'success'), 300);
        } catch(e) { sessionStorage.removeItem('eatup_toast'); }
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.addEventListener('submit', function (e) {
            const form = e.target;
            if (form.dataset.noLoading !== undefined) return;
            const btn = form.querySelector('button[type=submit]:not([data-no-loading])');
            if (!btn) return;
            const origHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:.9em;height:.9em;border-width:2px;vertical-align:middle;"></span>' + btn.textContent.trim();
            window.addEventListener('pageshow', function () { btn.disabled = false; btn.innerHTML = origHtml; }, { once: true });
        });
    });
</script>
@if (role == "Restaurant" && restaurantId > 0)
{
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
    (function () {
        const RESTAURANT_ID = @restaurantId;

        let audioCtx = null;
        let chimeTimer = null;

        function getCtx() {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            return audioCtx;
        }

        function playChime() {
            try {
                const ctx = getCtx();
                if (ctx.state === 'suspended') ctx.resume();
                [523, 659, 784, 1047].forEach((freq, i) => {       // C5-E5-G5-C6 arpeggio
                    const osc = ctx.createOscillator(), gain = ctx.createGain();
                    osc.connect(gain); gain.connect(ctx.destination);
                    osc.type = 'sine'; osc.frequency.value = freq;
                    const t = ctx.currentTime + i * 0.13;
                    gain.gain.setValueAtTime(0, t);
                    gain.gain.linearRampToValueAtTime(0.22, t + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.45);
                    osc.start(t); osc.stop(t + 0.5);
                });
            } catch (e) {}
        }

        function startChime() {
            if (chimeTimer) return;
            playChime();
            chimeTimer = setInterval(playChime, 8000);
        }

        function stopChime() {
            if (chimeTimer) { clearInterval(chimeTimer); chimeTimer = null; }
        }

        // audio context must resume after a user gesture due to browser autoplay policy
        document.addEventListener('click', function () {
            if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
        }, { once: true });

        window.dismissOrderNotif = function () {
            stopChime();
            const el = document.getElementById('orderNotifPopup');
            if (el) el.style.display = 'none';
        };

        function showNotif(order) {
            const el = document.getElementById('orderNotifPopup');
            if (!el) return;
            document.getElementById('orderNotifMsg').textContent =
                `#${order.restaurantOrderNumber} · ${order.total} RON · ${order.customerName}`;
            document.getElementById('orderNotifItems').textContent =
                (order.items || []).slice(0, 3).map(i => `${i.name} ×${i.qty}`).join(' · ');
            el.style.animation = 'none';
            el.offsetHeight;
            el.style.animation = '';
            el.style.display = 'block';
            startChime();
        }

        const conn = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/orders')
            .withAutomaticReconnect()
            .build();

        window.eatupOrderHub = conn;

        conn.onreconnecting(() =>
            document.dispatchEvent(new CustomEvent('eatup:reconnecting')));
        conn.onreconnected(() => {
            conn.invoke('JoinRestaurantGroup', RESTAURANT_ID).catch(() => {});
            document.dispatchEvent(new CustomEvent('eatup:reconnected'));
        });
        conn.onclose(() =>
            document.dispatchEvent(new CustomEvent('eatup:disconnected')));

        conn.on('order_incoming', function (order) {
            document.dispatchEvent(new CustomEvent('eatup:order_incoming', { detail: order }));
            showNotif(order);
        });

        conn.on('order_cancelled', function(orderId, restaurantOrderNumber) {
            playChime();
            showToast(`❌ Comanda #${restaurantOrderNumber} a fost anulată de client.`, 'error');
        });

        window.eatupHubPromise = conn.start()
            .then(() => {
                conn.invoke('JoinRestaurantGroup', RESTAURANT_ID).catch(() => {});
                document.dispatchEvent(new CustomEvent('eatup:connected'));
            })
            .catch(e => {
                document.dispatchEvent(new CustomEvent('eatup:disconnected'));
                console.error('SignalR connection error:', e);
            });
    })();
    </script>
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
