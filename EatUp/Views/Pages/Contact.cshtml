@{
    ViewData["Title"] = "Contact";
}

<section class="page-hero">
    <div class="container">
        <div class="page-hero-title">Contactează-ne</div>
        <p class="page-hero-sub">
            Suntem aici să te ajutăm. Scrie-ne sau sună-ne — răspundem în cel mai scurt timp.
        </p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-5">

            <div class="col-lg-4">
                <h5 class="fw-700 mb-4">Informații de contact</h5>
                <div class="d-flex flex-column gap-3">

                    <div class="contact-info-card">
                        <div class="contact-icon">📧</div>
                        <div>
                            <div class="fw-600 small mb-1">Email</div>
                            <a href="mailto:contact@eatup.ro" class="text-orange text-decoration-none small fw-500">
                                contact@eatup.ro
                            </a>
                        </div>
                    </div>

                    <div class="contact-info-card">
                        <div class="contact-icon">📞</div>
                        <div>
                            <div class="fw-600 small mb-1">Telefon</div>
                            <a href="tel:+40700000000" class="text-orange text-decoration-none small fw-500">
                                +40 700 000 000
                            </a>
                        </div>
                    </div>

                    <div class="contact-info-card">
                        <div class="contact-icon">📍</div>
                        <div>
                            <div class="fw-600 small mb-1">Adresă</div>
                            <span class="text-muted small">București, România</span>
                        </div>
                    </div>

                    <div class="contact-info-card">
                        <div class="contact-icon">🕐</div>
                        <div>
                            <div class="fw-600 small mb-1">Program suport</div>
                            <span class="text-muted small">Luni–Duminică, 08:00–23:00</span>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-lg-8">
                <div class="card-eatup p-4 p-md-5">
                    <h5 class="fw-700 mb-4">Trimite-ne un mesaj</h5>
                    <form id="contactForm" novalidate>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-600">Nume *</label>
                                <input type="text" id="cfName" class="form-control" placeholder="Numele tău complet" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-600">Email *</label>
                                <input type="email" id="cfEmail" class="form-control" placeholder="adresa@email.ro" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-600">Subiect *</label>
                            <select id="cfSubject" class="form-select" required>
                                <option value="">Selectează subiectul...</option>
                                <option value="order">Problemă comandă</option>
                                <option value="account">Cont</option>
                                <option value="partner">Restaurant partener</option>
                                <option value="other">Altele</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-600">Mesaj *</label>
                            <textarea id="cfMessage" class="form-control" rows="5"
                                      placeholder="Descrie problema sau întrebarea ta..." required
                                      style="resize:none;"></textarea>
                        </div>
                        <button type="submit" class="btn btn-orange fw-600 px-5 py-2" style="border-radius:12px;">
                            Trimite mesajul
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
<script>
document.getElementById('contactForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const name    = document.getElementById('cfName').value.trim();
    const email   = document.getElementById('cfEmail').value.trim();
    const subject = document.getElementById('cfSubject').value;
    const message = document.getElementById('cfMessage').value.trim();
    if (!name || !email || !subject || !message) {
        showToast('Completează toate câmpurile obligatorii.', 'error');
        return;
    }
    const token = document.querySelector('meta[name="request-verification-token"]')?.content;
    try {
        const res = await fetch('/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token || '' },
            body: JSON.stringify({ name, email, subject, message })
        });
        const data = await res.json();
        if (data.ok) {
            this.reset();
            showToast('Mesajul a fost trimis! Te vom contacta în curând.');
        } else {
            showToast(data.error || 'A apărut o eroare. Încearcă din nou.', 'error');
        }
    } catch {
        showToast('A apărut o eroare. Încearcă din nou.', 'error');
    }
});
</script>
}
