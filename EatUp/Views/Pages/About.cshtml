@{
    ViewData["Title"] = "Despre EatUp";
}

<section class="page-hero">
    <div class="container">
        <div class="page-hero-title">Despre EatUp</div>
        <p class="page-hero-sub">
            Misiunea noastră este să conectăm oamenii cu cele mai bune restaurante locale,
            oferind o experiență de comandă rapidă, simplă și plăcută.
        </p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-title">Procesul nostru</div>
            <h2 class="fw-800" style="font-size:1.75rem;">Cum funcționează EatUp?</h2>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">🔍</div>
                    <h5 class="fw-700 mb-2">1. Descoperă restaurante</h5>
                    <p class="text-muted small mb-0">
                        Caută după categorie, rating sau timp de livrare. Filtrează după preferințele tale și găsește restaurantul perfect.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">🛒</div>
                    <h5 class="fw-700 mb-2">2. Comandă simplu</h5>
                    <p class="text-muted small mb-0">
                        Adaugă produsele dorite în coș, alege metoda de plată și plasează comanda în câteva secunde.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">🚀</div>
                    <h5 class="fw-700 mb-2">3. Primești rapid</h5>
                    <p class="text-muted small mb-0">
                        Urmărește comanda în timp real pe hartă și bucură-te de mâncarea preferată livrată la ușa ta.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background:var(--gray-50);">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-title">Avantajele noastre</div>
            <h2 class="fw-800" style="font-size:1.75rem;">De ce EatUp?</h2>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">⚡</div>
                    <h6 class="fw-700 mb-2">Livrare rapidă</h6>
                    <p class="text-muted small mb-0">
                        Timp mediu de livrare sub 30 de minute, cu urmărire live a curierului.
                    </p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">✅</div>
                    <h6 class="fw-700 mb-2">Restaurante verificate</h6>
                    <p class="text-muted small mb-0">
                        Fiecare restaurant trece printr-un proces de verificare înainte de a fi listat pe platformă.
                    </p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">🔒</div>
                    <h6 class="fw-700 mb-2">Plată sigură</h6>
                    <p class="text-muted small mb-0">
                        Plăți procesate prin Stripe cu criptare SSL. Datele cardului tău sunt în siguranță.
                    </p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card text-center">
                    <div class="step-icon-card mx-auto">🎧</div>
                    <h6 class="fw-700 mb-2">Suport non-stop</h6>
                    <p class="text-muted small mb-0">
                        Echipa noastră de suport este disponibilă 7 zile din 7, 08:00–23:00.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-title">Impactul nostru</div>
            <h2 class="fw-800" style="font-size:1.75rem;">Cifrele noastre</h2>
        </div>
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">50+</div>
                    <div style="font-size:.875rem; color:rgba(255,255,255,.7);">Restaurante partenere</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">10.000+</div>
                    <div style="font-size:.875rem; color:rgba(255,255,255,.7);">Comenzi livrate</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">4.8★</div>
                    <div style="font-size:.875rem; color:rgba(255,255,255,.7);">Rating mediu</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">🇷🇴</div>
                    <div style="font-size:.875rem; color:rgba(255,255,255,.7);">Disponibil în toată România</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background:linear-gradient(135deg,var(--navy) 0%,#1e3a5f 100%);">
    <div class="container text-center">
        <h2 class="fw-800 text-white mb-3" style="font-size:1.75rem;">Gata să comanzi?</h2>
        <p class="mb-4" style="color:rgba(255,255,255,.7);">Înregistrează-te gratuit și bucură-te de prima comandă.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/account/register" class="btn btn-orange px-5 fw-600" style="border-radius:12px;">Înregistrare gratuită</a>
            <a href="/restaurants" class="btn fw-600 px-5" style="border-radius:12px; background:rgba(255,255,255,.12); color:white; border:1.5px solid rgba(255,255,255,.25);">
                Vezi restaurante
            </a>
        </div>
    </div>
</section>
