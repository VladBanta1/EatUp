@{
    ViewData["Title"] = "Devino partener EatUp";
}

<section class="page-hero">
    <div class="container">
        <div class="page-hero-title">Crește alături de EatUp</div>
        <p class="page-hero-sub">
            Alătură-te rețelei noastre de restaurante partenere și ajunge la mii de clienți noi în fiecare zi.
        </p>
        <a href="/account/register-restaurant" class="btn btn-orange fw-600 px-5 mt-3" style="border-radius:12px; font-size:1rem;">
            Înregistrează restaurantul
        </a>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-title">De ce EatUp?</div>
            <h2 class="fw-800" style="font-size:1.75rem;">Beneficiile parteneriatului</h2>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card h-100">
                    <div class="step-icon-card">📈</div>
                    <h6 class="fw-700 mb-2">Mai mulți clienți</h6>
                    <p class="text-muted small mb-0" style="line-height:1.7;">
                        Ajunge la mii de utilizatori EatUp care caută restaurante ca al tău. Fii vizibil pe
                        hartă și în listele de căutare, fără costuri de marketing.
                    </p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card h-100">
                    <div class="step-icon-card">📋</div>
                    <h6 class="fw-700 mb-2">Meniu ușor de gestionat</h6>
                    <p class="text-muted small mb-0" style="line-height:1.7;">
                        Actualizează categorii, produse și prețuri dintr-un panou intuitiv. Activează sau
                        dezactivează produse instantaneu în funcție de disponibilitate.
                    </p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card h-100">
                    <div class="step-icon-card">🔔</div>
                    <h6 class="fw-700 mb-2">Comenzi în timp real</h6>
                    <p class="text-muted small mb-0" style="line-height:1.7;">
                        Primești notificări instant pentru comenzi noi chiar în browser. Fără aplicație
                        mobilă necesară — funcționează de pe orice dispozitiv cu internet.
                    </p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="benefit-card h-100">
                    <div class="step-icon-card">📊</div>
                    <h6 class="fw-700 mb-2">Analiză și statistici</h6>
                    <p class="text-muted small mb-0" style="line-height:1.7;">
                        Urmărește veniturile, numărul de comenzi și cele mai vândute produse pe 7 sau 30 de
                        zile. Date clare pentru decizii de business mai bune.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background:var(--gray-50);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="section-title">Procesul de înregistrare</div>
                <h2 class="fw-800 mb-4" style="font-size:1.6rem;">Cum funcționează parteneriatul?</h2>
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex gap-3 align-items-start">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;flex-shrink:0;">1</div>
                        <div>
                            <h6 class="fw-700 mb-1">Completezi formularul</h6>
                            <p class="text-muted small mb-0">Adaugi datele restaurantului, logo-ul și programul de funcționare.</p>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;flex-shrink:0;">2</div>
                        <div>
                            <h6 class="fw-700 mb-1">Echipa noastră verifică cererea</h6>
                            <p class="text-muted small mb-0">Procesul durează 24–48 de ore. Te notificăm prin email cu rezultatul.</p>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;flex-shrink:0;">3</div>
                        <div>
                            <h6 class="fw-700 mb-1">Construiești meniul și ești live</h6>
                            <p class="text-muted small mb-0">Adaugi produsele și restaurantul apare imediat vizibil clienților.</p>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div style="width:32px;height:32px;border-radius:50%;background:var(--orange);color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;flex-shrink:0;">4</div>
                        <div>
                            <h6 class="fw-700 mb-1">Primești comenzi și câștigi</h6>
                            <p class="text-muted small mb-0">Gestionezi comenzile din dashboard și urmărești veniturile în timp real.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card-eatup p-5 text-center">
                    <div style="font-size:4rem; margin-bottom:1.25rem;">🍽️</div>
                    <h3 class="fw-800 mb-2">Gata să crești?</h3>
                    <p class="text-muted mb-4">Înregistrarea este gratuită. Comisionul se aplică doar pe comenzile procesate.</p>
                    <a href="/account/register-restaurant" class="btn btn-orange fw-600 w-100 py-3" style="border-radius:14px; font-size:1rem;">
                        Înregistrează restaurantul
                    </a>
                    <p class="text-muted small mt-3 mb-0">Ai întrebări? <a href="/contact" class="text-orange fw-600">Contactează-ne</a></p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container text-center">
        <h3 class="fw-800 mb-2">Ai întrebări?</h3>
        <p class="text-muted mb-4">Consultă secțiunea de întrebări frecvente sau contactează-ne direct.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/faq" class="btn btn-outline-orange fw-600 px-5" style="border-radius:12px;">Întrebări frecvente</a>
            <a href="/contact" class="btn btn-orange fw-600 px-5" style="border-radius:12px;">Contactează-ne</a>
        </div>
    </div>
</section>
